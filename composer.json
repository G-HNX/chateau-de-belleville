{
    "name": "chateau-belleville/vignoble-app",
    "description": "E-commerce platform for Chateau de Belleville vineyard",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "doctrine/orm": "^3.3",
        "dompdf/dompdf": "^3.1",
        "easycorp/easyadmin-bundle": "^4.28",
        "scheb/2fa-bundle": "^8.4",
        "scheb/2fa-email": "^8.4",
        "scheb/2fa-trusted-device": "^8.4",
        "stripe/stripe-php": "^19.3",
        "symfony/asset": "^7.2",
        "symfony/asset-mapper": "^7.2",
        "symfony/console": "^7.2",
        "symfony/dotenv": "^7.2",
        "symfony/flex": "^2",
        "symfony/form": "^7.2",
        "symfony/framework-bundle": "^7.2",
        "symfony/google-mailer": "^7.2",
        "symfony/html-sanitizer": "^7.2",
        "symfony/mailer": "^7.2",
        "symfony/mime": "^7.2",
        "symfony/monolog-bundle": "^3.10",
        "symfony/rate-limiter": "^7.2",
        "symfony/runtime": "^7.2",
        "symfony/security-bundle": "^7.2",
        "symfony/string": "^7.2",
        "symfony/twig-bundle": "^7.2",
        "symfony/uid": "^7.2",
        "symfony/ux-live-component": "^2.22",
        "symfony/ux-turbo": "^2.22",
        "symfony/ux-twig-component": "^2.22",
        "symfony/validator": "^7.2",
        "symfony/yaml": "^7.2",
        "symfonycasts/reset-password-bundle": "^1.24",
        "symfonycasts/tailwind-bundle": "^0.8",
        "symfonycasts/verify-email-bundle": "^1.18",
        "twig/extra-bundle": "^3.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.0",
        "phpunit/phpunit": "^12.5",
        "symfony/browser-kit": "^7.2",
        "symfony/css-selector": "^7.2",
        "symfony/debug-bundle": "^7.2",
        "symfony/maker-bundle": "^1.66",
        "symfony/stopwatch": "^7.2",
        "symfony/web-profiler-bundle": "^7.2"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "^7.2"
        }
    }
}
