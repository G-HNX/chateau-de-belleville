{% extends 'base.html.twig' %}

{% block title %}Contact - Château de Belleville{% endblock %}

{% block header %}
    <header class="page-header">
        <h1>Contact</h1>
        <p>Une question, une commande ou une réservation ? N'hésitez pas à nous contacter.</p>
    </header>
{% endblock %}

{% block body %}
    <section class="section section-white">
        <div class="container">
            <div class="grid-contact">
                {# Contact Info #}
                <div style="display: flex; flex-direction: column; gap: 2rem;">
                    <div class="contact-card" style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 10px 30px rgba(91, 70, 56, 0.1);" data-reveal="slide-left">
                        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                            <div style="width: 50px; height: 50px; background: var(--color-cream); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">📍</div>
                            <h3 style="font-family: var(--font-display); font-size: 1.3rem; color: var(--color-primary);">Adresse</h3>
                        </div>
                        <p style="color: var(--color-secondary); line-height: 1.8;">
                            Château de Belleville<br>
                            36 rue de la Garde<br>
                            79100 Sainte-Verge<br>
                            France
                        </p>
                    </div>

                    <div class="contact-card" style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 10px 30px rgba(91, 70, 56, 0.1);" data-reveal="slide-left" data-reveal-delay="120">
                        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                            <div style="width: 50px; height: 50px; background: var(--color-cream); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">📞</div>
                            <h3 style="font-family: var(--font-display); font-size: 1.3rem; color: var(--color-primary);">Téléphone & Email</h3>
                        </div>
                        <a href="tel:+33670327488" style="color: var(--color-secondary); text-decoration: none; display: block; line-height: 1.8;">06 70 32 74 88</a>
                        <a href="mailto:chateaudebelleville@gmail.com" style="color: var(--color-secondary); text-decoration: none; display: block; line-height: 1.8;">chateaudebelleville@gmail.com</a>
                    </div>

                    <div class="contact-card" style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 10px 30px rgba(91, 70, 56, 0.1);" data-reveal="slide-left" data-reveal-delay="240">
                        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                            <div style="width: 50px; height: 50px; background: var(--color-cream); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">🕐</div>
                            <h3 style="font-family: var(--font-display); font-size: 1.3rem; color: var(--color-primary);">Horaires d'ouverture</h3>
                        </div>
                        <div style="margin-top: 1rem;">
                            <div style="display: flex; justify-content: space-between; padding: 0.75rem 0; border-bottom: 1px solid var(--color-beige);">
                                <span style="color: var(--color-primary); font-weight: 500;">Vendredis</span>
                                <span style="color: var(--color-secondary);">10h-12h / 15h-18h30</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; padding: 0.75rem 0;">
                                <span style="color: var(--color-primary); font-weight: 500;">Autres jours</span>
                                <span style="color: var(--color-accent);">Sur rendez-vous</span>
                            </div>
                        </div>
                    </div>
                </div>

                {# Contact Form #}
                <div style="background: white; padding: 3rem; border-radius: 12px; box-shadow: 0 10px 30px rgba(91, 70, 56, 0.1);" data-reveal="slide-right" data-reveal-delay="100">
                    <h2 style="font-family: var(--font-display); font-size: 2rem; color: var(--color-primary); margin-bottom: 2rem;">Envoyez-nous un message</h2>
                    {{ form_start(form, {'attr': {'class': 'form-grid'}}) }}
                        <div class="form-group">
                            {{ form_label(form.nom) }}
                            {{ form_widget(form.nom) }}
                            {{ form_errors(form.nom) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.prenom) }}
                            {{ form_widget(form.prenom) }}
                            {{ form_errors(form.prenom) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email) }}
                            {{ form_errors(form.email) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.telephone) }}
                            {{ form_widget(form.telephone) }}
                            {{ form_errors(form.telephone) }}
                        </div>
                        <div class="form-group full-width">
                            {{ form_label(form.sujet) }}
                            {{ form_widget(form.sujet) }}
                            {{ form_errors(form.sujet) }}
                        </div>
                        <div class="form-group full-width">
                            {{ form_label(form.message) }}
                            {{ form_widget(form.message) }}
                            {{ form_errors(form.message) }}
                        </div>
                        <button type="submit" class="btn-submit">Envoyer le message</button>
                    {{ form_end(form) }}
                </div>
            </div>

            {# Map #}
            <div style="margin-top: 3rem;" data-reveal="fade-up">
                <div
                    data-controller="map"
                    data-map-lat-value="47.004759"
                    data-map-lng-value="-0.218672"
                    data-map-zoom-value="15"
                    data-map-label-value="Château de Belleville"
                    role="img" aria-label="Carte de localisation du Château de Belleville"
                    style="width: 100%; height: 400px; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 30px rgba(91, 70, 56, 0.12);"
                ></div>
                <div style="text-align: center; margin-top: 1.5rem;">
                    <p style="color: var(--color-secondary); line-height: 1.8;"><strong>Château de Belleville</strong> — 36 rue de la Garde, 79100 Sainte-Verge</p>
                    <div style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; margin-top: 1.25rem;">
                        <a href="https://www.google.com/maps/dir/?api=1&destination=36+rue+de+la+Garde,+79100+Sainte-Verge" target="_blank" rel="noopener"
                           style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; background: #4285F4; color: white; text-decoration: none; border-radius: 8px; font-weight: 500; font-size: 0.9rem;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                            Google Maps
                        </a>
                        <a href="https://maps.apple.com/?daddr=36+rue+de+la+Garde,+79100+Sainte-Verge" target="_blank" rel="noopener"
                           style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; background: #000; color: white; text-decoration: none; border-radius: 8px; font-weight: 500; font-size: 0.9rem;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                            Apple Plans
                        </a>
                    </div>
                </div>
            </div>

            {# Social #}
            <div style="text-align: center; padding: 3rem; background: var(--color-cream); border-radius: 12px; margin-top: 3rem;" data-reveal="fade-up">
                <h3 style="font-family: var(--font-display); font-size: 1.8rem; color: var(--color-primary); margin-bottom: 0.75rem;">Suivez-nous</h3>
                <p style="color: var(--color-secondary); font-size: 0.9rem; margin-bottom: 1.5rem;">Retrouvez nos actualités, vendanges et moments du domaine sur Instagram.</p>
                <a href="https://www.instagram.com/vin_chateaudebelleville_baron?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank" rel="noopener"
                   aria-label="Suivez-nous sur Instagram"
                   style="display: inline-flex; align-items: center; justify-content: center; width: 52px; height: 52px; background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); color: white; text-decoration: none; border-radius: 12px;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
            </div>
        </div>
    </section>
{% endblock %}
