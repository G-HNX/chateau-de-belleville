{% extends 'base.html.twig' %}

{% block title %}Vérifiez votre email - Château de Belleville{% endblock %}

{% block turbo_cache %}<meta name="turbo-cache-control" content="no-cache">{% endblock %}

{% block header %}
    <header class="page-header">
        <h1>Vérifiez votre email</h1>
        <p>Votre compte a été créé avec succès.</p>
    </header>
{% endblock %}

{% block body %}
    <section class="section section-white">
        <div class="container" style="max-width: 600px;">
            <div style="background: white; padding: 3rem; border-radius: 12px; box-shadow: 0 10px 40px rgba(91, 70, 56, 0.1); text-align: center;" data-reveal="fade-up">

                <div style="width: 72px; height: 72px; background: #F5F2ED; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 2rem; margin-bottom: 1.5rem;">
                    &#9993;
                </div>

                <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 600; color: var(--color-dark); margin: 0 0 1rem;">
                    Un email vous a été envoyé
                </h2>

                <p style="color: var(--color-secondary); line-height: 1.7; margin: 0 0 1.5rem; font-size: 0.95rem;">
                    Consultez votre boîte de réception et cliquez sur le lien de confirmation pour activer votre compte.
                    Le lien est valable <strong>1 heure</strong>.
                </p>

                <p style="color: var(--color-secondary); font-size: 0.85rem; margin: 0 0 2rem;">
                    Si vous ne trouvez pas l'email, vérifiez vos spams ou votre dossier courrier indésirable.
                </p>

                <div style="padding-top: 1.5rem; border-top: 1px solid var(--color-beige);">
                    <p style="color: var(--color-secondary); font-size: 0.9rem; margin: 0;">
                        Déjà un compte ?
                        <a href="{{ path('app_login') }}" style="color: var(--color-gold); text-decoration: none; font-weight: 500;">Se connecter</a>
                    </p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
