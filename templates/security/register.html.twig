{% extends 'base.html.twig' %}

{% block title %}Inscription - Château de Belleville{% endblock %}

{% block header %}
    <header class="page-header">
        <h1>Inscription</h1>
        <p>Créez votre compte pour profiter de tous nos services.</p>
    </header>
{% endblock %}

{% block body %}
    <section class="section section-white">
        <div class="container" style="max-width: 600px;">
            <div style="background: white; padding: 3rem; border-radius: 12px; box-shadow: 0 10px 40px rgba(91, 70, 56, 0.1);">
                <form method="post" class="form-grid">
                    <div class="form-group">
                        <label for="firstName">Prénom *</label>
                        <input type="text" id="firstName" name="firstName" required>
                    </div>
                    <div class="form-group">
                        <label for="lastName">Nom *</label>
                        <input type="text" id="lastName" name="lastName" required>
                    </div>
                    <div class="form-group full-width">
                        <label for="email">Email *</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label for="phone">Téléphone</label>
                        <input type="tel" id="phone" name="phone">
                    </div>
                    <div class="form-group">
                        &nbsp;
                    </div>
                    <div class="form-group">
                        <label for="password">Mot de passe *</label>
                        <input type="password" id="password" name="password" required minlength="6">
                        <small style="color: var(--color-secondary); margin-top: 0.3rem;">6 caractères minimum</small>
                    </div>
                    <div class="form-group">
                        <label for="confirmPassword">Confirmer *</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" required minlength="6">
                    </div>
                    <button type="submit" class="btn-submit">Créer mon compte</button>
                </form>

                <div style="text-align: center; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--color-beige);">
                    <p style="color: var(--color-secondary); font-size: 0.9rem;">
                        Déjà un compte ?
                        <a href="{{ path('app_login') }}" style="color: var(--color-gold); text-decoration: none; font-weight: 500;">Se connecter</a>
                    </p>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
