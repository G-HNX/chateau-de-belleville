{% extends 'base.html.twig' %}

{% block title %}Changer le mot de passe - Château de Belleville{% endblock %}

{% block header %}
    <header class="page-header">
        <h1>Mot de passe</h1>
        <p>Modifiez votre mot de passe.</p>
    </header>
{% endblock %}

{% block body %}
    <section class="section section-white">
        <div class="container">
            <div class="grid-sidebar">
                {% include 'account/_sidebar.html.twig' %}

                <div>
                    <h2 style="font-family: var(--font-display); font-size: 2rem; color: var(--color-primary); margin-bottom: 2rem;">Changer le mot de passe</h2>
                    <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(91, 70, 56, 0.08); max-width: 500px;" data-reveal="fade-up">
                        {{ form_start(form) }}
                            <div class="form-group" style="margin-bottom: 1.5rem;" data-controller="password">
                                {{ form_label(form.currentPassword) }}
                                {{ form_widget(form.currentPassword) }}
                                {{ form_errors(form.currentPassword) }}
                            </div>
                            <div class="form-group" style="margin-bottom: 1.5rem;" data-controller="password" data-password-strength-value="true">
                                {{ form_label(form.newPassword.first) }}
                                {{ form_widget(form.newPassword.first) }}
                                {{ form_errors(form.newPassword.first) }}
                            </div>
                            <div class="form-group" style="margin-bottom: 1.5rem;" data-controller="password">
                                {{ form_label(form.newPassword.second) }}
                                {{ form_widget(form.newPassword.second) }}
                                {{ form_errors(form.newPassword.second) }}
                            </div>
                            {{ form_errors(form.newPassword) }}
                            <button type="submit" class="btn btn-primary btn-full">Modifier le mot de passe</button>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
