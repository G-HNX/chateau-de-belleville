{% extends 'base.html.twig' %}

{% block title %}Changer le mot de passe - Château de Belleville{% endblock %}

{% block header %}
    <header class="page-header">
        <h1>Mot de passe</h1>
        <p>Modifiez votre mot de passe.</p>
    </header>
{% endblock %}

{% block body %}
    <section class="section section-white">
        <div class="container">
            <div class="grid-sidebar">
                {% include 'account/_sidebar.html.twig' %}

                <div>
                    <h2 style="font-family: var(--font-display); font-size: 2rem; color: var(--color-primary); margin-bottom: 2rem;">Changer le mot de passe</h2>
                    <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(91, 70, 56, 0.08); max-width: 500px;">
                        <form method="post">
                            <div class="form-group" style="margin-bottom: 1.5rem;">
                                <label for="currentPassword">Mot de passe actuel</label>
                                <input type="password" id="currentPassword" name="currentPassword" required>
                            </div>
                            <div class="form-group" style="margin-bottom: 1.5rem;">
                                <label for="newPassword">Nouveau mot de passe</label>
                                <input type="password" id="newPassword" name="newPassword" required minlength="6">
                                <small style="color: var(--color-secondary); margin-top: 0.3rem;">6 caractères minimum</small>
                            </div>
                            <div class="form-group" style="margin-bottom: 1.5rem;">
                                <label for="confirmPassword">Confirmer le nouveau mot de passe</label>
                                <input type="password" id="confirmPassword" name="confirmPassword" required minlength="6">
                            </div>
                            <button type="submit" class="btn btn-primary btn-full">Modifier le mot de passe</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
