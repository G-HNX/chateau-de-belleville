{% extends 'base.html.twig' %}

{% block title %}Mon Profil - Château de Belleville{% endblock %}

{% block header %}
    <header class="page-header">
        <h1>Mon Profil</h1>
        <p>Modifiez vos informations personnelles.</p>
    </header>
{% endblock %}

{% block body %}
    <section class="section section-white">
        <div class="container">
            <div class="grid-sidebar">
                {% include 'account/_sidebar.html.twig' %}

                <div>
                    <h2 style="font-family: var(--font-display); font-size: 2rem; color: var(--color-primary); margin-bottom: 2rem;">Informations personnelles</h2>
                    <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(91, 70, 56, 0.08); max-width: 600px;">
                        {{ form_start(form, {'attr': {'class': 'form-grid'}}) }}
                            <div class="form-group">
                                {{ form_label(form.firstName) }}
                                {{ form_widget(form.firstName) }}
                                {{ form_errors(form.firstName) }}
                            </div>
                            <div class="form-group">
                                {{ form_label(form.lastName) }}
                                {{ form_widget(form.lastName) }}
                                {{ form_errors(form.lastName) }}
                            </div>
                            <div class="form-group full-width">
                                <label for="email">Email</label>
                                <input type="email" id="email" value="{{ user.email }}" disabled style="background: var(--color-cream); cursor: not-allowed;">
                                <small style="color: var(--color-secondary); margin-top: 0.3rem;">L'email ne peut pas être modifié.</small>
                            </div>
                            <div class="form-group full-width">
                                {{ form_label(form.phone) }}
                                {{ form_widget(form.phone) }}
                                {{ form_errors(form.phone) }}
                            </div>
                            <button type="submit" class="btn-submit">Enregistrer</button>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
