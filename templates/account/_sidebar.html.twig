{# Account Sidebar Navigation #}
{% set currentRoute = app.request.attributes.get('_route') %}

<div style="background: white; border: 1px solid var(--color-beige); border-radius: 16px; overflow: hidden; position: sticky; top: 120px;">

    {# Avatar + nom #}
    <div style="background: linear-gradient(135deg, var(--color-primary) 0%, #3d2e24 100%); padding: 2rem; text-align: center;">
        <div style="width: 68px; height: 68px; background: rgba(201, 168, 124, 0.25); border: 2px solid rgba(201, 168, 124, 0.5); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; color: white; font-family: var(--font-display); font-size: 1.6rem;">
            {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
        </div>
        <div style="color: white; font-weight: 600; font-size: 1rem;">{{ app.user.fullName }}</div>
        <div style="color: rgba(255,255,255,0.55); font-size: 0.8rem; margin-top: 0.25rem;">{{ app.user.email }}</div>
    </div>

    {# Navigation #}
    <nav style="padding: 0.75rem;">
        {% set navItems = [
            {route: 'app_account_index',        label: 'Tableau de bord',   match: 'app_account_index',       icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>'},
            {route: 'app_account_orders',       label: 'Mes commandes',     match: 'app_account_order',       icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>'},
            {route: 'app_account_reservations', label: 'Mes réservations',  match: 'app_account_reservations', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>'},
            {route: 'app_account_favorites',    label: 'Mes vins',          match: 'app_account_favorites',   icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>'},
            {route: 'app_account_profile',      label: 'Mon profil',        match: 'app_account_profile',     icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>'},
            {route: 'app_account_addresses',    label: 'Mes adresses',      match: 'app_account_address',     icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>'},
            {route: 'app_account_password',     label: 'Mot de passe',      match: 'app_account_password',    icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>'}
        ] %}

        {% for item in navItems %}
            {% set isActive = currentRoute starts with item.match %}
            <a href="{{ path(item.route) }}" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 8px; text-decoration: none; margin-bottom: 0.15rem; transition: all 0.15s;
                {{ isActive
                    ? 'background: var(--color-cream); color: var(--color-primary); font-weight: 600;'
                    : 'color: var(--color-secondary);'
                }}">
                <span style="flex-shrink: 0; {{ isActive ? 'color: var(--color-primary);' : '' }}">{{ item.icon|raw }}</span>
                <span style="font-size: 0.9rem;">{{ item.label }}</span>
                {% if isActive %}
                    <span style="margin-left: auto; width: 6px; height: 6px; background: var(--color-gold); border-radius: 50%;"></span>
                {% endif %}
            </a>
        {% endfor %}

        <div style="height: 1px; background: var(--color-beige); margin: 0.75rem 0;"></div>

        <a href="{{ path('app_logout') }}" style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 8px; text-decoration: none; color: #C62828; font-size: 0.9rem; transition: background 0.15s;" onmouseover="this.style.background='#FFF5F5'" onmouseout="this.style.background='transparent'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Déconnexion
        </a>
    </nav>
</div>