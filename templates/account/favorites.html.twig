{% extends 'base.html.twig' %}

{% block title %}Mes Vins - Château de Belleville{% endblock %}

{% block header %}
    <header class="page-header">
        <h1>Mes Vins</h1>
        <p>Vos cuvées préférées, prêtes à être commandées.</p>
    </header>
{% endblock %}

{% block body %}
    <section class="section section-white">
        <div class="container">
            <div class="grid-sidebar">
                {% include 'account/_sidebar.html.twig' %}

                <div>
                    <h2 style="font-family: var(--font-display); font-size: 2rem; color: var(--color-primary); margin-bottom: 2rem;">Mes vins favoris</h2>

                    {% if favorites|length > 0 %}
                        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem;">
                            {% for wine in favorites %}
                                <div data-favorite-card style="background: white; border: 1px solid var(--color-beige); border-radius: 12px; overflow: hidden; display: flex; flex-direction: column;">
                                    {# Image #}
                                    <div style="background: var(--color-cream); height: 180px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;">
                                        {% if wine.category %}
                                            <span style="position: absolute; top: 0.75rem; left: 0.75rem; background: var(--color-primary); color: white; font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 20px; font-family: var(--font-body);">{{ wine.category.name }}</span>
                                        {% endif %}
                                        {% if wine.mainImage %}
                                            <img src="{{ asset('uploads/wines/' ~ wine.mainImage.filename) }}" alt="{{ wine.name }}" style="width: 100%; height: 100%; object-fit: cover;">
                                        {% else %}
                                            <div style="font-size: 4rem; opacity: 0.25;">🍷</div>
                                        {% endif %}
                                    </div>

                                    {# Contenu #}
                                    <div style="padding: 1rem; flex: 1; display: flex; flex-direction: column; gap: 0.5rem;">
                                        <h3 style="font-family: var(--font-display); font-size: 1.15rem; color: var(--color-primary); margin: 0;">{{ wine.name }}</h3>
                                        {% if wine.appellation %}
                                            <p style="font-size: 0.8rem; color: var(--color-secondary); margin: 0;">{{ wine.appellation }}{% if wine.vintage %} · {{ wine.vintage }}{% endif %}</p>
                                        {% endif %}
                                        <p style="font-size: 1.1rem; font-weight: 600; color: var(--color-dark); margin: 0;">{{ wine.formattedPrice }}</p>

                                        <div style="display: flex; gap: 0.5rem; margin-top: auto; padding-top: 0.75rem;">
                                            {% if wine.available %}
                                                <form action="{{ path('app_cart_add', {id: wine.id}) }}" method="post" style="flex: 1;"
                                                      data-controller="cart-add" data-action="submit->cart-add#add">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('cart_add') }}">
                                                    <input type="hidden" name="quantity" value="1">
                                                    <button type="submit" class="btn btn-primary btn-sm" style="width: 100%;" data-cart-add-target="button">Commander</button>
                                                </form>
                                            {% else %}
                                                <span class="btn btn-outline btn-sm" style="flex: 1; opacity: 0.5; cursor: default; text-align: center;">Indisponible</span>
                                            {% endif %}

                                            <button
                                                data-controller="favorite-toggle"
                                                data-favorite-toggle-wine-id-value="{{ wine.id }}"
                                                data-favorite-toggle-active-value="1"
                                                data-favorite-toggle-token-value="{{ csrf_token('favorite_' ~ wine.id) }}"
                                                data-favorite-toggle-remove-card-value="true"
                                                data-action="click->favorite-toggle#toggle"
                                                title="Retirer de mes vins"
                                                style="padding: 0.4rem 0.6rem; border: 1px solid var(--color-beige); background: white; border-radius: 6px; cursor: pointer; color: var(--color-primary); font-size: 1rem; line-height: 1; flex-shrink: 0;">
                                                <span data-heart-full style="display: block;">♥</span>
                                                <span data-heart-empty style="display: none;">♡</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div style="text-align: center; padding: 3rem; background: var(--color-cream); border-radius: 8px;">
                            <p style="color: var(--color-secondary); margin-bottom: 1rem;">Vous n'avez pas encore de vins favoris.</p>
                            <p style="font-size: 0.9rem; color: var(--color-secondary); margin-bottom: 1.5rem;">Cliquez sur le cœur ♡ dans la boutique pour retrouver vos cuvées préférées ici.</p>
                            <a href="{{ path('app_wine_index') }}" class="btn btn-primary">Découvrir nos vins</a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
{% endblock %}
