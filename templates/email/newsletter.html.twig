<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
</head>
<body style="font-family: 'Montserrat', Arial, sans-serif; color: #2C2420; background: #F5F2ED; margin: 0; padding: 0;">
    <div style="background: #5B4638; padding: 30px; text-align: center;">
        <h1 style="color: #C9A87C; font-family: Georgia, serif; margin: 0; font-size: 24px;">Château de Belleville</h1>
        <p style="color: #E8E3D9; margin: 5px 0 0; font-size: 14px;">Vignoble d'Anjou</p>
    </div>

    <div style="background: #ffffff; padding: 30px; margin: 0 auto; max-width: 600px;">
        {{ newsletter.content|sanitize_html }}
    </div>

    <div style="background: #F5F2ED; padding: 20px; text-align: center; border-top: 2px solid #E8E3D9;">
        <p style="color: #8B7355; font-size: 12px; margin: 0 0 8px;">
            Château de Belleville — Vignoble d'Anjou
        </p>
        <p style="color: #8B7355; font-size: 11px; margin: 0;">
            Vous recevez cet email car vous êtes abonné(e) à notre newsletter.<br>
            <a href="{{ unsubscribeUrl }}" style="color: #C9A87C; text-decoration: underline;">Se désinscrire</a>
        </p>
    </div>
</body>
</html>
