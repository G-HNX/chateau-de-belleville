{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe - Château de Belleville{% endblock %}

{% block header %}
    <header class="page-header">
        <h1>Nouveau mot de passe</h1>
        <p>Choisissez un mot de passe sécurisé pour votre compte.</p>
    </header>
{% endblock %}

{% block body %}
    <section class="section section-white">
        <div class="container" style="max-width: 500px;">
            <div style="background: white; padding: 3rem; border-radius: 12px; box-shadow: 0 10px 40px rgba(91, 70, 56, 0.1);" data-reveal="fade-up">

                {{ form_start(resetForm, {attr: {novalidate: 'novalidate'}}) }}
                    <div class="form-group" style="margin-bottom: 1rem;">
                        {{ form_label(resetForm.plainPassword.first, 'Nouveau mot de passe') }}
                        {{ form_widget(resetForm.plainPassword.first, {attr: {autofocus: true}}) }}
                        {{ form_errors(resetForm.plainPassword.first) }}
                    </div>
                    <div class="form-group" style="margin-bottom: 2rem;">
                        {{ form_label(resetForm.plainPassword.second, 'Confirmer le mot de passe') }}
                        {{ form_widget(resetForm.plainPassword.second) }}
                        {{ form_errors(resetForm.plainPassword.second) }}
                    </div>

                    <button type="submit" class="btn btn-primary btn-full">
                        Réinitialiser mon mot de passe
                    </button>
                {{ form_end(resetForm) }}
            </div>
        </div>
    </section>
{% endblock %}
