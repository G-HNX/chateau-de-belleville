{% extends 'base.html.twig' %}

{% block title %}Erreur {{ status_code }} - Château de Belleville{% endblock %}

{% block header %}{% endblock %}

{% block body %}
    <section style="min-height: 60vh; display: flex; align-items: center; justify-content: center; background: var(--color-cream); padding: 4rem 5%;">
        <div style="text-align: center; max-width: 560px;">
            <div style="font-size: 5rem; margin-bottom: 1.5rem;">🍇</div>
            <h1 style="font-family: var(--font-display); font-size: 3.5rem; color: var(--color-primary); margin-bottom: 0.5rem;">{{ status_code }}</h1>
            <h2 style="font-family: var(--font-display); font-size: 1.8rem; color: var(--color-primary); margin-bottom: 1.5rem;">Une erreur est survenue</h2>
            <p style="color: var(--color-secondary); line-height: 1.8; margin-bottom: 2.5rem;">
                Une erreur est survenue lors du traitement de votre demande.
                <br>Veuillez réessayer ou retourner à l'accueil.
            </p>
            <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                <a href="{{ path('app_home') }}" class="btn btn-primary">Retour à l'accueil</a>
                <a href="{{ path('app_wine_index') }}" class="btn btn-secondary">Voir nos vins</a>
                <a href="{{ path('app_contact') }}" class="btn btn-secondary">Contact</a>
            </div>
        </div>
    </section>
{% endblock %}
