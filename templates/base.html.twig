<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Château de Belleville{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Domaine viticole familial en Val de Loire. Découvrez nos vins d'exception et réservez une dégustation.{% endblock %}">
    <link rel="icon" href="{{ asset('images/logo.jpg') }}">

    {% block stylesheets %}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
    {# Navigation #}
    <div data-controller="mobile-menu">
        <nav class="site-nav" aria-label="Navigation principale">
            <div class="nav-container">
                <a href="{{ path('app_home') }}" class="logo">
                    <img src="{{ asset('images/logo.jpg') }}" alt="Logo Château de Belleville">
                    <span class="logo-text">
                        <span class="logo-title">Château de Belleville</span>
                        <span class="logo-subtitle">Vignoble d'Anjou</span>
                    </span>
                </a>

                <ul class="nav-links">
                    <li><a href="{{ path('app_domain') }}" {% if app.request.attributes.get('_route') == 'app_domain' %}class="active"{% endif %}>Le Domaine</a></li>
                    <li class="nav-separator" aria-hidden="true"></li>
                    <li><a href="{{ path('app_wine_index') }}" {% if app.request.attributes.get('_route') starts with 'app_wine' %}class="active"{% endif %}>Nos Vins</a></li>
                    <li class="nav-separator" aria-hidden="true"></li>
                    <li><a href="{{ path('app_tasting_index') }}" {% if app.request.attributes.get('_route') starts with 'app_tasting' %}class="active"{% endif %}>Dégustations</a></li>
                    <li class="nav-separator" aria-hidden="true"></li>
                    <li><a href="{{ path('app_contact') }}" {% if app.request.attributes.get('_route') == 'app_contact' %}class="active"{% endif %}>Contact</a></li>
                </ul>

                <div class="nav-actions">
                    <a href="{{ path('app_shop_index') }}" class="nav-boutique-btn">Boutique</a>
                    {% if app.user %}
                        <a href="{{ path('app_account_index') }}" class="nav-action-link" title="Mon compte">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span>Mon compte</span>
                        </a>
                        <a href="{{ path('app_logout') }}" class="nav-action-link" title="Déconnexion">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        </a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="nav-action-link" title="Connexion">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span>Connexion</span>
                        </a>
                    {% endif %}
                    <a href="{{ path('app_cart_index') }}" class="nav-cart-link" title="Panier">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        {% set count = cart_count() %}
                        <span id="cart-badge" class="cart-badge"{% if count == 0 %} style="display: none;"{% endif %}>{{ count }}</span>
                    </a>
                </div>

                {# Hamburger (mobile) #}
                <button class="hamburger" data-mobile-menu-target="hamburger" data-action="mobile-menu#toggle" aria-label="Menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </nav>

        {# Mobile overlay - outside nav to avoid backdrop-filter stacking context #}
        <div class="mobile-overlay" data-mobile-menu-target="overlay" data-action="click->mobile-menu#close"></div>

        {# Mobile menu - outside nav to avoid backdrop-filter stacking context #}
        <div class="mobile-menu" data-mobile-menu-target="menu">
            <button class="mobile-menu-close" data-action="mobile-menu#close" aria-label="Fermer le menu">✕</button>
            <ul class="mobile-menu-links">
                <li><a href="{{ path('app_home') }}" {% if app.request.attributes.get('_route') == 'app_home' %}class="active"{% endif %}>Accueil</a></li>
                <li><a href="{{ path('app_domain') }}" {% if app.request.attributes.get('_route') == 'app_domain' %}class="active"{% endif %}>Le Domaine</a></li>
                <li><a href="{{ path('app_wine_index') }}" {% if app.request.attributes.get('_route') starts with 'app_wine' %}class="active"{% endif %}>Nos Vins</a></li>
                <li><a href="{{ path('app_tasting_index') }}" {% if app.request.attributes.get('_route') starts with 'app_tasting' %}class="active"{% endif %}>Dégustations</a></li>
                <li><a href="{{ path('app_contact') }}" {% if app.request.attributes.get('_route') == 'app_contact' %}class="active"{% endif %}>Contact</a></li>
            </ul>
            <a href="{{ path('app_shop_index') }}" class="mobile-btn-boutique">Boutique</a>
            <div class="mobile-menu-actions">
                {% if app.user %}
                    <a href="{{ path('app_account_index') }}" class="mobile-btn-primary">Mon compte</a>
                    <a href="{{ path('app_logout') }}" class="mobile-btn-outline">Deconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="mobile-btn-primary">Connexion</a>
                {% endif %}
                <a href="{{ path('app_cart_index') }}" class="mobile-btn-outline">Panier{% if count > 0 %} ({{ count }}){% endif %}</a>
            </div>
        </div>
    </div>

    {# Flash Messages #}
    {% set flashes = app.flashes %}
    {% if flashes|length > 0 %}
        <div class="flash-container" role="status" aria-live="polite">
            {% for type, messages in flashes %}
                {% for message in messages %}
                    <div class="flash-message flash-{{ type }}" data-controller="flash" data-flash-delay-value="5000">
                        {{ message }}
                        <button class="flash-dismiss" data-action="flash#dismiss" aria-label="Fermer">✕</button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    {% endif %}

    {# Bandeau email non vérifié #}
    {% if app.user and not app.user.isVerified %}
        <div style="background: #fef3c7; border-bottom: 1px solid #f59e0b; padding: 0.75rem 1.5rem; text-align: center; font-size: 0.875rem; color: #92400e;">
            Votre adresse email n'est pas encore vérifiée. Consultez votre boîte de réception ou
            <a href="{{ path('app_resend_verification') }}" style="color: #92400e; font-weight: 600; text-decoration: underline;">renvoyer l'email de confirmation</a>.
        </div>
    {% endif %}

    {% block header %}{% endblock %}

    <main id="main-content">
        {% block body %}{% endblock %}
    </main>

    {# Footer #}
    <footer class="site-footer">
        <div class="footer-top-bar"></div>

        <div class="footer-inner">
            {# Colonne marque #}
            <div class="footer-brand">
                <p class="footer-brand-name">Château de Belleville</p>
                <p class="footer-brand-tagline">
                    Vignerons paysans passionnés, nous cultivons avec respect notre terroir
                    d'Anjou pour vous offrir des vins authentiques et de caractère.
                </p>
                <ul class="footer-contact-list">
                    <li>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        <span>36 rue de la Garde, 79100 Sainte-Verge</span>
                    </li>
                    <li>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.79a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.5 16l.42.92z"/></svg>
                        <span>06 70 32 74 88</span>
                    </li>
                    <li>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        <span>chateaudebelleville@gmail.com</span>
                    </li>
                </ul>
            </div>

            {# Navigation #}
            <div class="footer-section">
                <h4 class="footer-heading">Navigation</h4>
                <ul class="footer-links">
                    <li><a href="{{ path('app_domain') }}">Le Domaine</a></li>
                    <li><a href="{{ path('app_wine_index') }}">Nos Vins</a></li>
                    <li><a href="{{ path('app_shop_index') }}">Boutique</a></li>
                    <li><a href="{{ path('app_tasting_index') }}">Dégustations</a></li>
                    <li><a href="{{ path('app_contact') }}">Contact</a></li>
                </ul>
            </div>

            {# Informations #}
            <div class="footer-section">
                <h4 class="footer-heading">Informations</h4>
                <ul class="footer-links">
                    <li><a href="{{ path('app_legal') }}">Mentions légales</a></li>
                    <li><a href="{{ path('app_cgv') }}">CGV</a></li>
                    <li><a href="{{ path('app_privacy') }}">Politique de confidentialité</a></li>
                    <li><a href="{{ path('app_shipping') }}">Livraison</a></li>
                </ul>
            </div>

            {# Horaires & certifications #}
            <div class="footer-section">
                <h4 class="footer-heading">Horaires</h4>
                <div class="footer-hours">
                    <div class="footer-hours-row">
                        <span class="footer-hours-day">Vendredi</span>
                        <span>10h – 12h &nbsp;/&nbsp; 15h – 18h30</span>
                    </div>
                    <div class="footer-hours-row">
                        <span class="footer-hours-note">Autres jours sur rendez-vous</span>
                    </div>
                </div>
                <div class="footer-certif">
                    <span class="footer-certif-badge">Terra Vitis</span>
                    <span class="footer-certif-badge">HVE</span>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p class="footer-bottom-copy">&copy; {{ "now"|date("Y") }} Château de Belleville — Tous droits réservés</p>
            <p class="footer-bottom-alcohol">L'abus d'alcool est dangereux pour la santé, à consommer avec modération.</p>
        </div>
    </footer>

    {# Sommelier IA Widget #}
    {% include '_sommelier.html.twig' %}
</body>
</html>
