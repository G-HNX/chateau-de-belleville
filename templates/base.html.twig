<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Château de Belleville{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Domaine viticole familial en Val de Loire. Découvrez nos vins d'exception et réservez une dégustation.{% endblock %}">
    <link rel="canonical" href="{% block canonical %}{{ app.request ? app.request.schemeAndHttpHost ~ app.request.pathInfo : '' }}{% endblock %}">

    {# Open Graph #}
    <meta property="og:site_name" content="Château de Belleville">
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">
    <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
    <meta property="og:image" content="{% block og_image %}{{ app.request ? app.request.schemeAndHttpHost ~ asset('images/og-default.jpg') : '' }}{% endblock %}">
    <meta property="og:url" content="{{ app.request ? app.request.schemeAndHttpHost ~ app.request.requestUri : '' }}">
    <meta name="twitter:card" content="summary_large_image">

    <link rel="icon" href="{{ asset('images/logo.jpg') }}">

    {% block stylesheets %}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    {% endblock %}
    <style>
        /* Dropdown "Le Domaine"
           align-self: stretch hérité de .nav-links { align-items: stretch } dans app.css */
        .nav-has-dropdown {
            position: relative;
        }
        .nav-dropdown-trigger {
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.2em;
            /* hérite du style .nav-links a */
            font-size: 0.82rem;
            font-weight: 500;
            color: var(--color-secondary, #8B7355);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            transition: color 0.3s ease;
            user-select: none;
        }
        .nav-has-dropdown:hover .nav-dropdown-trigger,
        .nav-has-dropdown.active .nav-dropdown-trigger { color: var(--color-primary, #5B4638); }
        .nav-dropdown-trigger::after {
            content: '▾';
            font-size: 0.7em;
            opacity: 0.6;
            transition: transform 0.2s, opacity 0.2s;
            margin-left: 0.1em;
        }
        .nav-has-dropdown:hover .nav-dropdown-trigger::after { opacity: 1; transform: rotate(-180deg); }
        .nav-dropdown {
            display: none;
            position: absolute;
            top: 100%;          /* collé au bas du <li> qui fait 80px → collé à la nav */
            left: 50%;
            transform: translateX(-50%);
            background: #fff;
            border-top: 2px solid #C9A87C;
            box-shadow: 0 8px 28px rgba(44,36,32,0.13);
            min-width: 210px;
            z-index: 1100;      /* au-dessus de site-nav (z-index:1000) */
            list-style: none;
            padding: 0.4rem 0;
            margin: 0;
            border-radius: 0 0 4px 4px;
        }
        .nav-has-dropdown:hover .nav-dropdown { display: block; }
        .nav-dropdown li a {
            display: block;
            padding: 0.6rem 1.25rem;
            color: #2C2420;
            font-size: 0.78rem;
            font-family: 'Montserrat', sans-serif;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            font-weight: 400;
            text-decoration: none;
            transition: color 0.18s, background 0.18s;
            white-space: nowrap;
            text-align: center;
        }
        .nav-links .nav-dropdown li {
            display: block; /* spécificité (0,2,1) > .nav-links li (0,1,1) dans app.css */
        }
        .nav-dropdown li a:hover,
        .nav-dropdown li a.active { color: #5B4638; background: #F5F2ED; font-weight: 500; }
        /* Mobile sub-items */
        .mobile-menu-group-label { font-weight: 500; color: #2C2420; }
        .mobile-menu-sub-item a {
            padding-left: 2rem !important;
            font-size: 0.875rem !important;
            opacity: 0.8;
        }
    </style>

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
    {# Navigation #}
    <div data-controller="mobile-menu">
        <nav class="site-nav" aria-label="Navigation principale">
            <div class="nav-container">
                <a href="{{ path('app_home') }}" class="logo">
                    <img src="{{ asset('images/logo.jpg') }}" alt="Logo Château de Belleville">
                    <span class="logo-text">
                        <span class="logo-title">Château de Belleville</span>
                        <span class="logo-subtitle">Vignoble d'Anjou</span>
                    </span>
                </a>

                <ul class="nav-links">
                    {% set domainActive = app.request.attributes.get('_route') starts with 'app_domain' or app.request.attributes.get('_route') starts with 'app_news' %}
                    <li class="nav-has-dropdown {% if domainActive %}active{% endif %}">
                        <span class="nav-dropdown-trigger">Le Domaine</span>
                        <ul class="nav-dropdown">
                            <li><a href="{{ path('app_domain') }}" {% if app.request.attributes.get('_route') == 'app_domain' %}class="active"{% endif %}>Le Domaine</a></li>
                            <li><a href="{{ path('app_domain_excellence') }}" {% if app.request.attributes.get('_route') == 'app_domain_excellence' %}class="active"{% endif %}>Notre Excellence</a></li>
                            <li><a href="{{ path('app_domain_nature') }}" {% if app.request.attributes.get('_route') == 'app_domain_nature' %}class="active"{% endif %}>Nature &amp; Durabilité</a></li>
                            <li><a href="{{ path('app_domain_transmission') }}" {% if app.request.attributes.get('_route') == 'app_domain_transmission' %}class="active"{% endif %}>Transmission</a></li>
                            <li><a href="{{ path('app_news_index') }}" {% if app.request.attributes.get('_route') starts with 'app_news' %}class="active"{% endif %}>Actualités</a></li>
                        </ul>
                    </li>
                    <li class="nav-separator" aria-hidden="true"></li>
                    <li><a href="{{ path('app_wine_index') }}" {% if app.request.attributes.get('_route') starts with 'app_wine' %}class="active"{% endif %}>Nos Vins</a></li>
                    <li class="nav-separator" aria-hidden="true"></li>
                    <li><a href="{{ path('app_tasting_index') }}" {% if app.request.attributes.get('_route') starts with 'app_tasting' %}class="active"{% endif %}>Dégustations</a></li>
                    <li class="nav-separator" aria-hidden="true"></li>
                    <li><a href="{{ path('app_contact') }}" {% if app.request.attributes.get('_route') == 'app_contact' %}class="active"{% endif %}>Contact</a></li>
                </ul>

                <div class="nav-actions">
                    <a href="{{ path('app_shop_index') }}" class="nav-boutique-btn">Boutique</a>
                    {% if app.user %}
                        <a href="{{ path('app_account_index') }}" class="nav-action-link" title="Mon compte">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span>Mon compte</span>
                        </a>
                        <a href="{{ path('app_logout') }}" class="nav-action-link" title="Déconnexion">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        </a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="nav-action-link" title="Connexion">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span>Connexion</span>
                        </a>
                    {% endif %}
                    <a href="{{ path('app_cart_index') }}" class="nav-cart-link" title="Panier">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        {% set count = cart_count() %}
                        <span id="cart-badge" class="cart-badge" aria-live="polite" aria-atomic="true" aria-label="{{ count }} article{{ count != 1 ? 's' : '' }} dans le panier"{% if count == 0 %} style="display: none;"{% endif %}>{{ count }}</span>
                    </a>
                </div>

                {# Hamburger (mobile) #}
                <button class="hamburger" data-mobile-menu-target="hamburger" data-action="mobile-menu#toggle" aria-label="Menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </nav>

        {# Mobile overlay - outside nav to avoid backdrop-filter stacking context #}
        <div class="mobile-overlay" data-mobile-menu-target="overlay" data-action="click->mobile-menu#close"></div>

        {# Mobile menu - outside nav to avoid backdrop-filter stacking context #}
        <div class="mobile-menu" data-mobile-menu-target="menu">
            <button class="mobile-menu-close" data-action="mobile-menu#close" aria-label="Fermer le menu">✕</button>
            <ul class="mobile-menu-links">
                <li><a href="{{ path('app_home') }}" {% if app.request.attributes.get('_route') == 'app_home' %}class="active"{% endif %}>Accueil</a></li>
                <li class="mobile-menu-group-label"><a href="{{ path('app_domain') }}" {% if app.request.attributes.get('_route') == 'app_domain' %}class="active"{% endif %}>Le Domaine</a></li>
                <li class="mobile-menu-sub-item"><a href="{{ path('app_domain_excellence') }}" {% if app.request.attributes.get('_route') == 'app_domain_excellence' %}class="active"{% endif %}>Notre Excellence</a></li>
                <li class="mobile-menu-sub-item"><a href="{{ path('app_domain_nature') }}" {% if app.request.attributes.get('_route') == 'app_domain_nature' %}class="active"{% endif %}>Nature &amp; Durabilité</a></li>
                <li class="mobile-menu-sub-item"><a href="{{ path('app_domain_transmission') }}" {% if app.request.attributes.get('_route') == 'app_domain_transmission' %}class="active"{% endif %}>Transmission</a></li>
                <li class="mobile-menu-sub-item"><a href="{{ path('app_news_index') }}" {% if app.request.attributes.get('_route') starts with 'app_news' %}class="active"{% endif %}>Actualités</a></li>
                <li><a href="{{ path('app_wine_index') }}" {% if app.request.attributes.get('_route') starts with 'app_wine' %}class="active"{% endif %}>Nos Vins</a></li>
                <li><a href="{{ path('app_tasting_index') }}" {% if app.request.attributes.get('_route') starts with 'app_tasting' %}class="active"{% endif %}>Dégustations</a></li>
                <li><a href="{{ path('app_contact') }}" {% if app.request.attributes.get('_route') == 'app_contact' %}class="active"{% endif %}>Contact</a></li>
            </ul>
            <a href="{{ path('app_shop_index') }}" class="mobile-btn-boutique">Boutique</a>
            <div class="mobile-menu-actions">
                {% if app.user %}
                    <a href="{{ path('app_account_index') }}" class="mobile-btn-primary">Mon compte</a>
                    <a href="{{ path('app_logout') }}" class="mobile-btn-outline">Deconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="mobile-btn-primary">Connexion</a>
                {% endif %}
                <a href="{{ path('app_cart_index') }}" class="mobile-btn-outline">Panier{% if count > 0 %} ({{ count }}){% endif %}</a>
            </div>
        </div>
    </div>

    {# Flash Messages #}
    {% set flashes = app.flashes %}
    {% if flashes|length > 0 %}
        <div class="flash-container" role="status" aria-live="polite">
            {% for type, messages in flashes %}
                {% for message in messages %}
                    <div class="flash-message flash-{{ type }}" data-controller="flash" data-flash-delay-value="5000">
                        {{ message }}
                        <button class="flash-dismiss" data-action="flash#dismiss" aria-label="Fermer">✕</button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    {% endif %}

    {# Bandeau email non vérifié #}
    {% if app.user and not app.user.isVerified %}
        <div style="background: #fef3c7; border-bottom: 1px solid #f59e0b; padding: 0.75rem 1.5rem; text-align: center; font-size: 0.875rem; color: #92400e;">
            Votre adresse email n'est pas encore vérifiée. Consultez votre boîte de réception ou
            <a href="{{ path('app_resend_verification') }}" style="color: #92400e; font-weight: 600; text-decoration: underline;">renvoyer l'email de confirmation</a>.
        </div>
    {% endif %}

    {% block header %}{% endblock %}

    <main id="main-content">
        {% block body %}{% endblock %}
    </main>

    {# Footer #}
    <footer class="site-footer">
        <div class="footer-top-bar"></div>

        <div class="footer-inner">
            {# Colonne marque #}
            <div class="footer-brand">
                <p class="footer-brand-name">Château de Belleville</p>
                <p class="footer-brand-tagline">
                    Vignerons paysans passionnés, nous cultivons avec respect notre terroir
                    d'Anjou pour vous offrir des vins authentiques et de caractère.
                </p>
                <ul class="footer-contact-list">
                    <li>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        <span>36 rue de la Garde, 79100 Sainte-Verge</span>
                    </li>
                    <li>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1.21h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.79a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.5 16l.42.92z"/></svg>
                        <span>06 70 32 74 88</span>
                    </li>
                    <li>
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        <span>chateaudebelleville@gmail.com</span>
                    </li>
                </ul>
            </div>

            {# Navigation #}
            <div class="footer-section">
                <h4 class="footer-heading">Navigation</h4>
                <ul class="footer-links">
                    <li><a href="{{ path('app_domain') }}">Le Domaine</a></li>
                    <li><a href="{{ path('app_wine_index') }}">Nos Vins</a></li>
                    <li><a href="{{ path('app_shop_index') }}">Boutique</a></li>
                    <li><a href="{{ path('app_tasting_index') }}">Dégustations</a></li>
                    <li><a href="{{ path('app_news_index') }}">Actualités</a></li>
                    <li><a href="{{ path('app_contact') }}">Contact</a></li>
                </ul>
            </div>

            {# Informations #}
            <div class="footer-section">
                <h4 class="footer-heading">Informations</h4>
                <ul class="footer-links">
                    <li><a href="{{ path('app_legal') }}">Mentions légales</a></li>
                    <li><a href="{{ path('app_cgv') }}">CGV</a></li>
                    <li><a href="{{ path('app_privacy') }}">Politique de confidentialité</a></li>
                    <li><a href="{{ path('app_shipping') }}">Livraison</a></li>
                </ul>
            </div>

            {# Horaires & certifications #}
            <div class="footer-section">
                <h4 class="footer-heading">Horaires</h4>
                <div class="footer-hours">
                    <div class="footer-hours-row">
                        <span class="footer-hours-day">Vendredi</span>
                        <span>10h – 12h &nbsp;/&nbsp; 15h – 18h30</span>
                    </div>
                    <div class="footer-hours-row">
                        <span class="footer-hours-note">Autres jours sur rendez-vous</span>
                    </div>
                </div>
                <div class="footer-certif">
                    <div style="display: inline-block; background: white; border-radius: 8px; padding: 6px 10px;">
                        <img src="{{ asset('images/terra-vitis.png') }}" alt="Certification Terra Vitis – Viticulture durable" style="height: 40px; width: auto; display: block;">
                    </div>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p class="footer-bottom-copy">&copy; {{ "now"|date("Y") }} Château de Belleville — Tous droits réservés</p>
            <p class="footer-bottom-alcohol">L'abus d'alcool est dangereux pour la santé, à consommer avec modération.</p>
        </div>
    </footer>

    {# Sommelier IA Widget #}
    {% include '_sommelier.html.twig' %}

    {# Bannière consentement cookies + vérification âge (RGPD) #}
    <div data-controller="cookie-consent">
        <div data-cookie-consent-target="banner"
             hidden
             style="
                position: fixed; inset: 0; z-index: 9999;
                display: flex; align-items: center; justify-content: center;
                background: rgba(44, 36, 32, 0.82);
                backdrop-filter: blur(3px);
                padding: 1rem;
             ">
            <div style="
                background: #F5F2ED;
                border-top: 3px solid #C9A87C;
                border-radius: 4px;
                box-shadow: 0 16px 48px rgba(44, 36, 32, 0.3);
                max-width: 560px;
                width: 100%;
                padding: 2.5rem 2rem;
                text-align: center;
                font-family: 'Montserrat', sans-serif;
            ">
                <p style="font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 600; color: #2C2420; margin: 0 0 0.5rem;">
                    Château de Belleville
                </p>
                <p style="font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: #8B7355; margin: 0 0 1.5rem;">
                    Vignoble d'Anjou
                </p>

                <p style="font-size: 0.9rem; color: #2C2420; margin: 0 0 0.75rem; line-height: 1.6;">
                    Ce site présente et vend des <strong>vins et alcools</strong>.<br>
                    Vous devez avoir <strong>au moins 18 ans</strong> pour y accéder.
                </p>
                <p style="font-size: 0.8rem; color: #5B4638; margin: 0 0 0.5rem; line-height: 1.6;">
                    Nous utilisons des <strong>cookies techniques</strong> (session, sécurité) indispensables au fonctionnement du site,
                    et des <strong>cookies fonctionnels</strong> optionnels (mémorisation de connexion).
                </p>
                <p style="font-size: 0.78rem; color: #8B7355; margin: 0 0 1.75rem; line-height: 1.5;">
                    <a href="{{ path('app_privacy') }}" target="_blank" style="color: #C9A87C; text-decoration: underline;">
                        Consulter notre politique de confidentialité &amp; cookies
                    </a>
                </p>

                <div style="display: flex; flex-direction: column; gap: 0.65rem;">
                    <button data-action="cookie-consent#acceptAll"
                            style="
                                background: #5B4638; color: #F5F2ED;
                                border: none; border-radius: 2px;
                                padding: 0.875rem 1.5rem;
                                font-family: 'Montserrat', sans-serif;
                                font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase;
                                font-weight: 500; cursor: pointer;
                                transition: background 0.2s;
                            "
                            onmouseover="this.style.background='#8B7355'"
                            onmouseout="this.style.background='#5B4638'">
                        J'ai 18 ans — Accepter tous les cookies
                    </button>
                    <button data-action="cookie-consent#acceptNecessary"
                            style="
                                background: transparent; color: #5B4638;
                                border: 1px solid #A08D7A; border-radius: 2px;
                                padding: 0.75rem 1.5rem;
                                font-family: 'Montserrat', sans-serif;
                                font-size: 0.78rem; letter-spacing: 0.06em; text-transform: uppercase;
                                cursor: pointer;
                                transition: background 0.2s, border-color 0.2s;
                            "
                            onmouseover="this.style.background='rgba(91,70,56,0.06)'"
                            onmouseout="this.style.background='transparent'">
                        J'ai 18 ans — Cookies nécessaires uniquement
                    </button>
                    <button data-action="cookie-consent#decline"
                            style="
                                background: transparent; color: #A08D7A;
                                border: none;
                                padding: 0.5rem 1rem;
                                font-family: 'Montserrat', sans-serif;
                                font-size: 0.72rem; letter-spacing: 0.06em;
                                cursor: pointer;
                                text-decoration: underline;
                            ">
                        Quitter le site (je n'ai pas 18 ans)
                    </button>
                </div>

                <p style="margin: 1.5rem 0 0; font-size: 0.7rem; color: #A08D7A;">
                    L'abus d'alcool est dangereux pour la santé, à consommer avec modération.
                </p>
            </div>
        </div>
    </div>
</body>
</html>
