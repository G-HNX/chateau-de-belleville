{% extends 'base.html.twig' %}

{% block title %}Commande - Château de Belleville{% endblock %}

{% block header %}
    <header class="page-header">
        <h1>Finaliser la commande</h1>
        <p>Renseignez vos informations pour valider votre achat.</p>
    </header>
{% endblock %}

{% block body %}
    <nav class="checkout-steps" aria-label="Étapes de commande">
        <div class="container">
            <div class="checkout-steps-inner">
                <div class="checkout-step active">
                    <span class="checkout-step-num">1</span>
                    <span class="checkout-step-label">Coordonnées</span>
                </div>
                <div class="checkout-step-sep"></div>
                <div class="checkout-step">
                    <span class="checkout-step-num">2</span>
                    <span class="checkout-step-label">Paiement</span>
                </div>
                <div class="checkout-step-sep"></div>
                <div class="checkout-step">
                    <span class="checkout-step-num">3</span>
                    <span class="checkout-step-label">Confirmation</span>
                </div>
            </div>
        </div>
    </nav>

    <section class="section section-white">
        <div class="container">
            {{ form_start(form, {'action': path('app_checkout_index')}) }}
                <div class="grid-checkout">
                    {# Form #}
                    <div data-reveal="slide-left">
                        {# Contact Info (guest only) #}
                        {% if not app.user %}
                            <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(91, 70, 56, 0.08); margin-bottom: 2rem;">
                                <h3 style="font-family: var(--font-display); font-size: 1.5rem; color: var(--color-primary); margin-bottom: 1.5rem;">Vos coordonnées</h3>
                                <div class="form-grid">
                                    <div class="form-group">
                                        {{ form_label(form.firstName) }}
                                        {{ form_widget(form.firstName) }}
                                        {{ form_errors(form.firstName) }}
                                    </div>
                                    <div class="form-group">
                                        {{ form_label(form.lastName) }}
                                        {{ form_widget(form.lastName) }}
                                        {{ form_errors(form.lastName) }}
                                    </div>
                                    <div class="form-group">
                                        {{ form_label(form.email) }}
                                        {{ form_widget(form.email) }}
                                        {{ form_errors(form.email) }}
                                    </div>
                                    <div class="form-group">
                                        {{ form_label(form.phone) }}
                                        {{ form_widget(form.phone) }}
                                        {{ form_errors(form.phone) }}
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                        {# Billing Address #}
                        <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(91, 70, 56, 0.08); margin-bottom: 2rem;">
                            <h3 style="font-family: var(--font-display); font-size: 1.5rem; color: var(--color-primary); margin-bottom: 1.5rem;">Adresse de facturation</h3>
                            <div class="form-grid">
                                <div class="form-group">
                                    {{ form_label(form.billingAddress.firstName) }}
                                    {{ form_widget(form.billingAddress.firstName) }}
                                    {{ form_errors(form.billingAddress.firstName) }}
                                </div>
                                <div class="form-group">
                                    {{ form_label(form.billingAddress.lastName) }}
                                    {{ form_widget(form.billingAddress.lastName) }}
                                    {{ form_errors(form.billingAddress.lastName) }}
                                </div>
                                <div class="form-group full-width">
                                    {{ form_label(form.billingAddress.street) }}
                                    {{ form_widget(form.billingAddress.street) }}
                                    {{ form_errors(form.billingAddress.street) }}
                                </div>
                                <div class="form-group">
                                    {{ form_label(form.billingAddress.zipCode) }}
                                    {{ form_widget(form.billingAddress.zipCode) }}
                                    {{ form_errors(form.billingAddress.zipCode) }}
                                </div>
                                <div class="form-group">
                                    {{ form_label(form.billingAddress.city) }}
                                    {{ form_widget(form.billingAddress.city) }}
                                    {{ form_errors(form.billingAddress.city) }}
                                </div>
                            </div>
                            {{ form_widget(form.billingAddress.country) }}
                        </div>

                        {# Same address checkbox + Shipping Address #}
                        <div data-controller="same-address">
                            <div style="background: white; padding: 1rem 2rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(91, 70, 56, 0.08); margin-bottom: 2rem;">
                                <label style="display: flex; align-items: center; gap: 0.75rem; cursor: pointer; font-weight: 500; color: var(--color-primary);">
                                    {{ form_widget(form.sameAsBilling, {'attr': {'data-same-address-target': 'checkbox', 'data-action': 'same-address#toggle', 'style': 'width: 18px; height: 18px; accent-color: var(--color-primary);'}}) }}
                                    Livrer à la même adresse que la facturation
                                </label>
                            </div>

                            <div data-same-address-target="shippingBlock" style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(91, 70, 56, 0.08); margin-bottom: 2rem;">
                                <h3 style="font-family: var(--font-display); font-size: 1.5rem; color: var(--color-primary); margin-bottom: 1.5rem;">Adresse de livraison</h3>
                                <div class="form-grid">
                                    <div class="form-group">
                                        {{ form_label(form.shippingAddress.firstName) }}
                                        {{ form_widget(form.shippingAddress.firstName) }}
                                        {{ form_errors(form.shippingAddress.firstName) }}
                                    </div>
                                    <div class="form-group">
                                        {{ form_label(form.shippingAddress.lastName) }}
                                        {{ form_widget(form.shippingAddress.lastName) }}
                                        {{ form_errors(form.shippingAddress.lastName) }}
                                    </div>
                                    <div class="form-group full-width">
                                        {{ form_label(form.shippingAddress.street) }}
                                        {{ form_widget(form.shippingAddress.street) }}
                                        {{ form_errors(form.shippingAddress.street) }}
                                    </div>
                                    <div class="form-group">
                                        {{ form_label(form.shippingAddress.zipCode) }}
                                        {{ form_widget(form.shippingAddress.zipCode) }}
                                        {{ form_errors(form.shippingAddress.zipCode) }}
                                    </div>
                                    <div class="form-group">
                                        {{ form_label(form.shippingAddress.city) }}
                                        {{ form_widget(form.shippingAddress.city) }}
                                        {{ form_errors(form.shippingAddress.city) }}
                                    </div>
                                </div>
                                {{ form_widget(form.shippingAddress.country) }}
                            </div>
                        </div>

                        {# Notes #}
                        <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(91, 70, 56, 0.08); margin-bottom: 2rem;">
                            <div class="form-group">
                                {{ form_label(form.notes) }}
                                {{ form_widget(form.notes) }}
                                {{ form_errors(form.notes) }}
                            </div>
                        </div>

                        {# Vérification d'âge #}
                        <div style="background: #fefce8; border: 1px solid #fde68a; padding: 2rem; border-radius: 12px;">
                            <h3 style="font-family: var(--font-display); font-size: 1.4rem; color: var(--color-primary); margin-bottom: 0.5rem;">Vérification de majorité</h3>
                            <p style="font-size: 0.9rem; color: var(--color-secondary); margin-bottom: 1.5rem;">La vente d'alcool est strictement réservée aux personnes majeures (18 ans et plus). Cette information est conservée à des fins légales.</p>
                            <div class="form-group" style="margin-bottom: 1.25rem;">
                                {{ form_label(form.birthDate) }}
                                {{ form_widget(form.birthDate) }}
                                {{ form_errors(form.birthDate) }}
                            </div>
                            <div class="form-group">
                                <label style="display: flex; align-items: flex-start; gap: 0.75rem; cursor: pointer; font-size: 0.9rem; color: var(--color-dark); line-height: 1.4;">
                                    {{ form_widget(form.ageVerification, {'attr': {'style': 'width: 18px; height: 18px; accent-color: var(--color-primary); flex-shrink: 0; margin-top: 2px;'}}) }}
                                    Je certifie avoir 18 ans ou plus et accepte de recevoir des produits alcoolisés.
                                </label>
                                {{ form_errors(form.ageVerification) }}
                            </div>
                        </div>
                    </div>

                    {# Order Summary #}
                    <div class="checkout-order-summary" data-reveal="slide-right" data-reveal-delay="150">
                        <h3 style="font-family: var(--font-display); font-size: 1.5rem; color: var(--color-primary); margin-bottom: 1.5rem;">Récapitulatif</h3>
                        {% for item in cart.items %}
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid var(--color-beige);">
                                <div>
                                    <div style="font-weight: 500; color: var(--color-primary);">{{ item.wine.name }}</div>
                                    <div style="font-size: 0.85rem; color: var(--color-secondary);">x{{ item.quantity }}</div>
                                </div>
                                <div style="font-weight: 500;">{{ (item.totalInCents / 100)|number_format(2, ',', ' ') }} €</div>
                            </div>
                        {% endfor %}

                        <div style="margin-top: 1.5rem;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
                                <span style="color: var(--color-secondary);">Sous-total</span>
                                <span>{{ (cart.totalInCents / 100)|number_format(2, ',', ' ') }} €</span>
                            </div>
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
                                <span style="color: var(--color-secondary);">Livraison</span>
                                <span>{% if cart.totalInCents >= 15000 %}Offerte{% else %}À calculer{% endif %}</span>
                            </div>
                            <div style="height: 1px; background: var(--color-beige); margin: 1rem 0;"></div>
                            <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 0.3rem;">
                                <span style="font-family: var(--font-display); font-size: 1.3rem; color: var(--color-primary);">Total TTC</span>
                                <span style="font-family: var(--font-display); font-size: 1.5rem; color: var(--color-gold); font-weight: 600;">{{ (cart.totalInCents / 100)|number_format(2, ',', ' ') }} €</span>
                            </div>
                            <div style="text-align: right; font-size: 0.8rem; color: var(--color-secondary);">dont TVA 20% : {{ (cart.totalInCents / 600)|number_format(2, ',', ' ') }} €</div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-full" style="margin-top: 1.5rem;">Valider la commande</button>
                        <a href="{{ path('app_cart_index') }}" style="display: block; text-align: center; margin-top: 1rem; color: var(--color-secondary); text-decoration: none; font-size: 0.9rem;">← Retour au panier</a>
                    </div>
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}
