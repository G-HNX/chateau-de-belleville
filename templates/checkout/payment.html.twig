{% extends 'base.html.twig' %}

{% block title %}Paiement - Château de Belleville{% endblock %}

{% block header %}
    <header class="page-header">
        <h1>Paiement sécurisé</h1>
        <p>Finalisez votre commande {{ order.reference }}</p>
    </header>
{% endblock %}

{% block body %}
    <nav class="checkout-steps" aria-label="Étapes de commande">
        <div class="container">
            <div class="checkout-steps-inner">
                <div class="checkout-step done">
                    <span class="checkout-step-num">✓</span>
                    <span class="checkout-step-label">Coordonnées</span>
                </div>
                <div class="checkout-step-sep done"></div>
                <div class="checkout-step active">
                    <span class="checkout-step-num">2</span>
                    <span class="checkout-step-label">Paiement</span>
                </div>
                <div class="checkout-step-sep"></div>
                <div class="checkout-step">
                    <span class="checkout-step-num">3</span>
                    <span class="checkout-step-label">Confirmation</span>
                </div>
            </div>
        </div>
    </nav>

    <section class="section section-white">
        <div class="container" style="max-width: 900px;">
            <div class="grid-checkout">
                {# Stripe Payment Form #}
                <div data-reveal="slide-left"
                    data-controller="stripe-payment"
                    data-stripe-payment-public-key-value="{{ stripePublicKey }}"
                    data-stripe-payment-client-secret-value="{{ clientSecret }}"
                    data-stripe-payment-return-url-value="{{ url('app_checkout_confirmation', {reference: order.reference}) }}"
                >
                    <div style="background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 15px rgba(91, 70, 56, 0.08);">
                        <h3 style="font-family: var(--font-display); font-size: 1.5rem; color: var(--color-primary); margin-bottom: 1.5rem;">Informations de paiement</h3>

                        <div id="payment-element" data-stripe-payment-target="paymentElement" style="margin-bottom: 1.5rem;"></div>

                        <div id="payment-errors" data-stripe-payment-target="errors" style="color: #e74c3c; font-size: 0.9rem; margin-bottom: 1rem; display: none;"></div>

                        <button
                            type="button"
                            class="btn btn-primary btn-full"
                            data-stripe-payment-target="submitButton"
                            data-action="stripe-payment#submit"
                            style="margin-top: 1rem;"
                        >
                            <span data-stripe-payment-target="buttonText">Payer {{ (order.totalInCents / 100)|number_format(2, ',', ' ') }} €</span>
                            <span data-stripe-payment-target="spinner" style="display: none;">Traitement en cours...</span>
                        </button>
                    </div>

                    <div style="text-align: center; margin-top: 1.5rem;">
                        <p style="color: var(--color-secondary); font-size: 0.85rem;">
                            Paiement sécurisé par Stripe. Vos données bancaires ne transitent jamais par nos serveurs.
                        </p>
                    </div>
                </div>

                {# Order Summary #}
                <div class="checkout-order-summary" data-reveal="slide-right" data-reveal-delay="150">
                    <h3 style="font-family: var(--font-display); font-size: 1.5rem; color: var(--color-primary); margin-bottom: 1.5rem;">Récapitulatif</h3>

                    <div style="font-size: 0.8rem; text-transform: uppercase; color: var(--color-secondary); margin-bottom: 0.5rem;">Commande {{ order.reference }}</div>

                    {% for item in order.items %}
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 0; border-bottom: 1px solid var(--color-beige);">
                            <div>
                                <div style="font-weight: 500; color: var(--color-primary);">{{ item.wineName }}</div>
                                <div style="font-size: 0.85rem; color: var(--color-secondary);">x{{ item.quantity }}</div>
                            </div>
                            <div style="font-weight: 500;">{{ (item.totalInCents / 100)|number_format(2, ',', ' ') }} €</div>
                        </div>
                    {% endfor %}

                    <div style="margin-top: 1.5rem;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
                            <span style="color: var(--color-secondary);">Sous-total</span>
                            <span>{{ (order.subtotalInCents / 100)|number_format(2, ',', ' ') }} €</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.75rem;">
                            <span style="color: var(--color-secondary);">Livraison</span>
                            <span>{% if order.shippingCostInCents == 0 %}Offerte{% else %}{{ (order.shippingCostInCents / 100)|number_format(2, ',', ' ') }} €{% endif %}</span>
                        </div>
                        <div style="height: 1px; background: var(--color-beige); margin: 1rem 0;"></div>
                        <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 0.3rem;">
                            <span style="font-family: var(--font-display); font-size: 1.3rem; color: var(--color-primary);">Total TTC</span>
                            <span style="font-family: var(--font-display); font-size: 1.5rem; color: var(--color-gold); font-weight: 600;">{{ (order.totalInCents / 100)|number_format(2, ',', ' ') }} €</span>
                        </div>
                        <div style="text-align: right; font-size: 0.8rem; color: var(--color-secondary);">dont TVA 20% : {{ (order.taxAmountInCents / 100)|number_format(2, ',', ' ') }} €</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
