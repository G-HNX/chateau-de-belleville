{% extends 'base.html.twig' %}

{% block title %}Désinscription newsletter — Château de Belleville{% endblock %}

{% block body %}
<section style="min-height: 60vh; display: flex; align-items: center; justify-content: center; padding: 4rem 1.5rem; background: var(--color-cream, #F5F2ED);">
    <div style="text-align: center; max-width: 480px;">
        {% if success %}
            <p style="font-size: 2.5rem; margin-bottom: 1rem;">✓</p>
            <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--color-dark, #2C2420); margin-bottom: 1rem;">
                Désinscription confirmée
            </h1>
            <p style="font-size: 0.9rem; color: var(--color-secondary, #8B7355); line-height: 1.6; margin-bottom: 2rem;">
                Votre adresse email a bien été retirée de notre liste de diffusion.
                Vous ne recevrez plus nos actualités.
            </p>
        {% else %}
            <p style="font-size: 2.5rem; margin-bottom: 1rem;">⚠</p>
            <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--color-dark, #2C2420); margin-bottom: 1rem;">
                Lien invalide
            </h1>
            <p style="font-size: 0.9rem; color: var(--color-secondary, #8B7355); line-height: 1.6; margin-bottom: 2rem;">
                Ce lien de désinscription est invalide ou a déjà été utilisé.
            </p>
        {% endif %}
        <a href="{{ path('app_home') }}" style="
            display: inline-block;
            background: var(--color-primary, #5B4638);
            color: #F5F2ED;
            padding: 0.75rem 2rem;
            font-family: 'Montserrat', sans-serif;
            font-size: 0.8rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            text-decoration: none;
            border-radius: 2px;
        ">Retour à l'accueil</a>
    </div>
</section>
{% endblock %}
