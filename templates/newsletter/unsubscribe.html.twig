{% extends 'base.html.twig' %}

{% block title %}Désinscription newsletter — Château de Belleville{% endblock %}

{% block header %}
    <header class="page-header">
        <h1>Newsletter</h1>
    </header>
{% endblock %}

{% block body %}
<section class="section section-cream">
    <div class="container" style="max-width: 560px; text-align: center; padding: 3rem 1.5rem;">
        {% if success %}
            <div style="font-size: 3rem; color: var(--color-gold); margin-bottom: 1.5rem;">✓</div>
            <h2 style="font-family: var(--font-display); font-size: 2rem; color: var(--color-primary); margin-bottom: 1rem;">
                Désinscription confirmée
            </h2>
            <p style="color: var(--color-secondary); line-height: 1.7; margin-bottom: 2.5rem;">
                Votre adresse email a bien été retirée de notre liste de diffusion.<br>
                Vous ne recevrez plus nos actualités.
            </p>
        {% else %}
            <div style="font-size: 3rem; color: var(--color-secondary); margin-bottom: 1.5rem;">⚠</div>
            <h2 style="font-family: var(--font-display); font-size: 2rem; color: var(--color-primary); margin-bottom: 1rem;">
                Lien invalide
            </h2>
            <p style="color: var(--color-secondary); line-height: 1.7; margin-bottom: 2.5rem;">
                Ce lien de désinscription est invalide ou a déjà été utilisé.
            </p>
        {% endif %}
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
            <a href="{{ path('app_home') }}" class="btn btn-primary">Retour à l'accueil</a>
            <a href="{{ path('app_wine_index') }}" class="btn btn-secondary">Voir nos vins</a>
        </div>
    </div>
</section>
{% endblock %}
