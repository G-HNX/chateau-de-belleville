# =============================================================
# Château de Belleville — Variables d'environnement PRODUCTION
# =============================================================
# Copiez ce fichier en .env.local et remplissez les valeurs.
# .env.local n'est JAMAIS commité (présent dans .gitignore).
# =============================================================

APP_ENV=prod
APP_SECRET=GÉNÉRER_AVEC_php_bin_console_secrets_generate-keys

# Base de données (MySQL O2switch)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/DB_NAME?serverVersion=10.6.0-MariaDB"

# Mailer (SMTP O2switch ou Gmail)
MAILER_DSN=smtp://USER:PASSWORD@mail.chateaudebelleville.fr:465?encryption=ssl

# Stripe (clés live, pas test)
STRIPE_SECRET_KEY=VOTRE_CLÉ_SECRÈTE_STRIPE
STRIPE_PUBLIC_KEY=VOTRE_CLÉ_PUBLIQUE_STRIPE
STRIPE_WEBHOOK_SECRET=VOTRE_SECRET_WEBHOOK_STRIPE

# Sommelier IA (Google AI Studio — gratuit)
SOMMELIER_AI_API_KEY=VOTRE_CLÉ_GOOGLE_AI_STUDIO
SOMMELIER_AI_MODEL=gemini-2.0-flash

# URL de base pour les emails (commandes, réservations)
DEFAULT_URI=https://chateaudebelleville.fr
